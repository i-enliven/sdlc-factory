          "name": "run_cli_command",
          "response": {
            "result": "import { test, expect } from '@playwright/test';\n\ntest.describe('Dimensional Factor Pulse UI', () => {\n  test.beforeEach(async ({ page }) => {\n    // Mock the API response to ensure deterministic rendering during tests\n    await page.route('**/api/**', async route => {\n      const json = {\n        data: [\n          {\n            id: 'US Core Equity',\n            data: [\n              { x: '2023-10-01', y: 0.0123, region: 'US', proxyPair: 'A/B' },\n              { x: '2023-10-02', y: -0.0045, region: 'US', proxyPair: 'A/B' }\n            ]\n          }\n        ]\n      };\n      await route.fulfill({ json });\n    });\n\n    await page.goto('/');\n  });\n\n  test('should render the header', async ({ page }) => {\n    await expect(page.locator('text=Dimensional Factor Pulse')).toBeVisible();\n  });\n\n  test('should render the fund selector dropdown', async ({ page }) => {\n    // The fund selector should be present\n    await expect(page.locator('text=US Core Equity').first()).toBeVisible();\n  });\n\n  test('should render the timeframe toggles', async ({ page }) => {\n    const timeframes = ['1D', '5D', '1M', '6M', '1Y', 'YTD'];\n    for (const tf of timeframes) {\n      await expect(page.locator(`text=${tf}`).first()).toBeVisible();\n    }\n  });\n\n  test('should render the footer', async ({ page }) => {\n    await expect(page.locator('text=Built by SDLC-Factory')).toBeVisible();\n  });\n\n  test('should render the heatmap', async ({ page }) => {\n    // Heatmap could be SVG or Canvas depending on the library (nivo or apexcharts)\n    const heatmap = page.locator('svg, canvas').first();\n    await expect(heatmap).toBeVisible();\n  });\n});\n"
          }
        },
