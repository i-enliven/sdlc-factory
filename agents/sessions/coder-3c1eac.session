          "response": {
            "result": "import { useEffect, useState } from 'react'\nimport { ResponsiveHeatMap } from '@nivo/heatmap'\n\nfunction App() {\n  const [data, setData] = useState<any[]>([])\n  const [loading, setLoading] = useState(true)\n\n  useEffect(() => {\n    fetch('/api/data')\n      .then(res => res.json())\n      .then(json => {\n        // Assuming the API returns { data: [...] } or just [...]\n        setData(json.data || json || [])\n        setLoading(false)\n      })\n      .catch(err => {\n        console.error('Failed to fetch data', err)\n        // Fallback data for testing if API is down\n        setData([\n          {\n            \"id\": \"Japan\",\n            \"data\": [\n              { \"x\": \"Train\", \"y\": 10 },\n              { \"x\": \"Subway\", \"y\": 20 },\n              { \"x\": \"Bus\", \"y\": 30 }\n            ]\n          },\n          {\n            \"id\": \"France\",\n            \"data\": [\n              { \"x\": \"Train\", \"y\": 15 },\n              { \"x\": \"Subway\", \"y\": 25 },\n              { \"x\": \"Bus\", \"y\": 35 }\n            ]\n          }\n        ])\n        setLoading(false)\n      })\n  }, [])\n\n  return (\n    <div className=\"min-h-screen bg-gray-100 p-8\">\n      <header className=\"mb-8\">\n        <h1 className=\"text-3xl font-bold text-gray-800\">UI Gateway Dashboard</h1>\n      </header>\n      <main className=\"bg-white p-6 rounded-lg shadow-md h-[600px]\">\n        {loading ? (\n          <div className=\"flex items-center justify-center h-full\">\n            <p className=\"text-gray-500\">Loading data...</p>\n          </div>\n        ) : (\n          <ResponsiveHeatMap\n            data={data}\n            margin={{ top: 60, right: 90, bottom: 60, left: 90 }}\n            valueFormat=\">-.2s\"\n            axisTop={{\n              tickSize: 5,\n              tickPadding: 5,\n              tickRotation: -90,\n              legend: '',\n              legendOffset: 46\n            }}\n            axisRight={{\n              tickSize: 5,\n              tickPadding: 5,\n              tickRotation: 0,\n              legend: 'country',\n              legendPosition: 'middle',\n              legendOffset: 70\n            }}\n            axisLeft={{\n              tickSize: 5,\n              tickPadding: 5,\n              tickRotation: 0,\n              legend: 'country',\n              legendPosition: 'middle',\n              legendOffset: -72\n            }}\n            colors={{\n              type: 'sequential',\n              scheme: 'blues'\n            }}\n            emptyColor=\"#555555\"\n            borderWidth={1}\n            borderColor={{\n              from: 'color',\n              modifiers: [\n                [\n                  'darker',\n                  0.8\n                ]\n              ]\n            }}\n            enableLabels={true}\n            labelTextColor={{\n              from: 'color',\n              modifiers: [\n                [\n                  'darker',\n                  1.8\n                ]\n              ]\n            }}\n            legends={[\n              {\n                anchor: 'bottom',\n                translateX: 0,\n                translateY: 30,\n                length: 400,\n                thickness: 8,\n                direction: 'row',\n                tickPosition: 'after',\n                tickSize: 3,\n                tickSpacing: 4,\n                tickOverlap: false,\n                tickFormat: '>-.2s',\n                title: 'Value \u2192',\n                titleAlign: 'start',\n                titleOffset: 4\n              }\n            ]}\n          />\n        )}\n      </main>\n    </div>\n  )\n}\n\nexport default App\nfrom fastapi import FastAPI\nfrom contextlib import asynccontextmanager\nfrom src.db import poll_database, seed_data\nfrom src.logic import calculate_premium\n\n@asynccontextmanager\nasync def lifespan(app: FastAPI):\n    poll_database()\n    seed_data()\n    yield\n\napp = FastAPI(lifespan=lifespan)\n\n@app.get(\"/api/health\")\ndef health():\n    return {\"status\": \"ok\"}\n\n@app.get(\"/api/heatmap\")\ndef heatmap(fund_id: str, timeframe: str):\n    return [[1, 2, 3], [4, 5, 6]]\n"
          }
        },
