        "file_data": null,
        "function_call": {
          "id": null,
          "args": {
            "command": "cat << 'EOF' > src/data_fetcher.py\nimport yfinance as yf\nimport pandas as pd\nfrom datetime import datetime, timedelta\nfrom src.db import SessionLocal, PremiumData\nfrom src.logic import calculate_premium\n\nPAIRS = {\n    \"DFAC\": \"^GSPC\",\n    \"DXIV\": \"URTH\",\n    \"DFAE\": \"EEM\"\n}\n\ndef fetch_data():\n    tickers = list(PAIRS.keys()) + list(PAIRS.values())\n    end_date = datetime.now()\n    start_date = end_date - timedelta(days=730)\n    \n    df = yf.download(tickers, start=start_date, end=end_date)\n    \n    if df.empty:\n        return\n        \n    # yfinance returns MultiIndex columns if multiple tickers are downloaded\n    # We need 'Adj Close' or 'Close'\n    if 'Adj Close' in df.columns.levels[0]:\n        price_df = df['Adj Close']\n    else:\n        price_df = df['Close']\n        \n    # Calculate daily returns\n    returns_df = price_df.pct_change().dropna()\n    \n    db = SessionLocal()\n    try:\n        # Clear existing data to avoid duplicates on restart\n        db.query(PremiumData).delete()\n        \n        records = []\n        for date, row in returns_df.iterrows():\n            for fund, bench in PAIRS.items():\n                if pd.notna(row[fund]) and pd.notna(row[bench]):\n                    premium = calculate_premium(row[fund], row[bench])\n                    records.append(PremiumData(\n                        fund_id=fund,\n                        date=date.date(),\n                        premium=premium\n                    ))\n        \n        if records:\n            db.bulk_save_objects(records)\n            db.commit()\n    except Exception as e:\n        db.rollback()\n        print(f\"Error saving data: {e}\")\n    finally:\n        db.close()\nEOF"
          },
          "name": "run_cli_command",
          "partial_args": null,
          "will_continue": null
        },
