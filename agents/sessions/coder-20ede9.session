        "function_call": {
          "id": null,
          "args": {
            "command": "cat << 'EOF' > src/main.py\nfrom fastapi import FastAPI, Depends, Query, HTTPException\nfrom sqlalchemy.orm import Session\nfrom sqlalchemy import text\nfrom typing import Optional, List\nfrom datetime import datetime, timedelta\nfrom pydantic import BaseModel\nimport os\n\nfrom src.db import get_db, init_db, engine\nfrom src.data_fetcher import fetch_data\nfrom src.db import PremiumData\n\n# Initialize DB and fetch data before binding the port\n# We only do this if not in a test environment where we might want to mock it,\n# but for this task, we can just run it.\n# To avoid yfinance calls during simple tests, we can check an env var.\nif os.getenv(\"TESTING\") != \"1\":\n    init_db()\n    try:\n        fetch_data()\n    except Exception as e:\n        print(f\"Error fetching data: {e}\")\n\napp = FastAPI()\n\nclass HealthResponse(BaseModel):\n    status: str\n    db_connected: bool\n\nclass DataPoint(BaseModel):\n    x: str\n    y: float\n\nclass HeatmapResponse(BaseModel):\n    id: str\n    data: List[DataPoint]\n\n@app.get(\"/health\", response_model=HealthResponse)\ndef health_check(db: Session = Depends(get_db)):\n    db_connected = False\n    try:\n        db.execute(text(\"SELECT 1\"))\n        db_connected = True\n    except Exception:\n        pass\n    return {\"status\": \"ok\", \"db_connected\": db_connected}\n\n@app.get(\"/api/heatmap\", response_model=List[HeatmapResponse])\ndef get_heatmap(\n    timeframe: str = Query(..., description=\"Timeframe (e.g., 1M, 6M, 1Y)\"),\n    fund_id: Optional[str] = Query(None, description=\"Optional fund ID\"),\n    db: Session = Depends(get_db)\n):\n    days = 30\n    if timeframe.endswith('M'):\n        try:\n            days = int(timeframe[:-1]) * 30\n        except ValueError:\n            pass\n    elif timeframe.endswith('Y'):\n        try:\n            days = int(timeframe[:-1]) * 365\n        except ValueError:\n            pass\n    elif timeframe.endswith('D'):\n        try:\n            days = int(timeframe[:-1])\n        except ValueError:\n            pass\n            \n    start_date = datetime.now().date() - timedelta(days=days)\n    \n    query = db.query(PremiumData).filter(PremiumData.date >= start_date)\n    if fund_id:\n        query = query.filter(PremiumData.fund_id == fund_id)\n        \n    results = query.order_by(PremiumData.date).all()\n    \n    grouped = {}\n    for row in results:\n        if row.fund_id not in grouped:\n            grouped[row.fund_id] = []\n        grouped[row.fund_id].append({\n            \"x\": row.date.isoformat(),\n            \"y\": row.premium\n        })\n        \n    response = []\n    for fid, data in grouped.items():\n        response.append({\n            \"id\": fid,\n            \"data\": data\n        })\n        \n    return response\nEOF"
          },
