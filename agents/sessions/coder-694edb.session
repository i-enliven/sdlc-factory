            "result": "[project]\nname = \"logic-api\"\nversion = \"0.1.0\"\ndescription = \"The Python backend logic engine.\"\nreadme = \"README.md\"\nrequires-python = \">=3.10\"\ndependencies = [\n    \"fastapi>=0.110.0\",\n    \"uvicorn>=0.29.0\",\n    \"yfinance>=0.2.37\",\n    \"psycopg2-binary>=2.9.9\",\n    \"httpx>=0.27.0\",\n    \"pytest>=8.1.1\"\n]\n\n[build-system]\nrequires = [\"hatchling\"]\nbuild-backend = \"hatchling.build\"\n\n[tool.hatch.build.targets.wheel]\npackages = [\"src\"]\nfrom fastapi import FastAPI\nfrom contextlib import asynccontextmanager\nfrom src.db import poll_database, seed_data\nfrom src.logic import calculate_premium\n\n@asynccontextmanager\nasync def lifespan(app: FastAPI):\n    poll_database()\n    seed_data()\n    yield\n\napp = FastAPI(lifespan=lifespan)\n\n@app.get(\"/api/health\")\ndef health():\n    return {\"status\": \"ok\"}\n\n@app.get(\"/api/heatmap\")\ndef heatmap(fund_id: str, timeframe: str):\n    return [[1, 2, 3], [4, 5, 6]]\n"
          }
        },
