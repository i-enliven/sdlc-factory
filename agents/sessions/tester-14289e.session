        "function_call": {
          "id": null,
          "args": {
            "command": "mkdir -p ui-gateway/tests\ncat << 'EOF' > ui-gateway/tests/e2e.spec.ts\nimport { test, expect } from '@playwright/test';\n\ntest.describe('Dimensional Factor Pulse UI', () => {\n  test.beforeEach(async ({ page }) => {\n    // Mock the API response to ensure deterministic rendering during tests\n    await page.route('**/api/**', async route => {\n      const json = {\n        data: [\n          {\n            id: 'US Core Equity',\n            data: [\n              { x: '2023-10-01', y: 0.0123, region: 'US', proxyPair: 'A/B' },\n              { x: '2023-10-02', y: -0.0045, region: 'US', proxyPair: 'A/B' }\n            ]\n          }\n        ]\n      };\n      await route.fulfill({ json });\n    });\n\n    await page.goto('/');\n  });\n\n  test('should render the header', async ({ page }) => {\n    await expect(page.locator('text=Dimensional Factor Pulse')).toBeVisible();\n  });\n\n  test('should render the fund selector dropdown', async ({ page }) => {\n    // The fund selector should be present\n    await expect(page.locator('text=US Core Equity').first()).toBeVisible();\n  });\n\n  test('should render the timeframe toggles', async ({ page }) => {\n    const timeframes = ['1D', '5D', '1M', '6M', '1Y', 'YTD'];\n    for (const tf of timeframes) {\n      await expect(page.locator(`text=${tf}`).first()).toBeVisible();\n    }\n  });\n\n  test('should render the footer', async ({ page }) => {\n    await expect(page.locator('text=Built by SDLC-Factory')).toBeVisible();\n  });\n\n  test('should render the heatmap', async ({ page }) => {\n    // Heatmap could be SVG or Canvas depending on the library (nivo or apexcharts)\n    const heatmap = page.locator('svg, canvas').first();\n    await expect(heatmap).toBeVisible();\n  });\n});\nEOF\n\ncat << 'EOF' > ui-gateway/playwright.config.ts\nimport { defineConfig, devices } from '@playwright/test';\n\nexport default defineConfig({\n  testDir: './tests',\n  fullyParallel: true,\n  forbidOnly: !!process.env.CI,\n  retries: process.env.CI ? 2 : 0,\n  workers: process.env.CI ? 1 : undefined,\n  reporter: 'list',\n  use: {\n    baseURL: 'http://localhost:8000',\n    trace: 'on-first-retry',\n  },\n  projects: [\n    {\n      name: 'chromium',\n      use: { ...devices['Desktop Chrome'] },\n    },\n  ],\n});\nEOF\n\nmkdir -p handoff\ncat << 'EOF' > handoff/test_payload.json\n{\n  \"status\": \"success\",\n  \"phase_completed\": \"TEST_DESIGN\",\n  \"module_id\": \"ui-gateway\",\n  \"test_files_created\": [\n    \"ui-gateway/tests/e2e.spec.ts\",\n    \"ui-gateway/playwright.config.ts\"\n  ]\n}\nEOF\n"
          },
