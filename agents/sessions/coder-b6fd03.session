            "result": "import os\nimport pytest\n\ndef test_init_sql_exists():\n    assert os.path.exists(\"src/init.sql\"), \"init.sql must exist in src directory\"\n\ndef test_init_sql_contains_tables():\n    with open(\"src/init.sql\", \"r\") as f:\n        content = f.read().lower()\n        \n    assert \"create table\" in content, \"init.sql must create tables\"\n    assert \"date\" in content, \"Table should have a date column\"\n    assert \"adjusted_close\" in content or \"price\" in content or \"close\" in content, \"Table should have an adjusted close or price column\"\n    assert \"symbol\" in content or \"ticker\" in content or \"fund_id\" in content or \"benchmark_id\" in content, \"Table should have a symbol/ticker/fund column\"\n\n"
          }
        },
        "inline_data": null,
        "text": null,
        "thought": null,
