          "name": "run_cli_command",
          "response": {
            "result": "import pytest\nfrom unittest.mock import patch, MagicMock\n\ndef test_calculate_premium():\n    from src.logic import calculate_premium\n    dfa_return = 0.01555\n    bench_return = 0.01000\n    premium = calculate_premium(dfa_return, bench_return)\n    assert premium == round(dfa_return - bench_return, 4)\n\n@patch(\"src.data_fetcher.yf.download\")\ndef test_fetch_data(mock_yf_download):\n    from src.data_fetcher import fetch_data\n    mock_df = MagicMock()\n    mock_yf_download.return_value = mock_df\n    \n    fetch_data()\n    \n    args, kwargs = mock_yf_download.call_args\n    tickers = args[0] if args else kwargs.get(\"tickers\", \"\")\n    assert \"DFAC\" in tickers\n    assert \"^GSPC\" in tickers\n    assert \"DXIV\" in tickers\n    assert \"URTH\" in tickers\n    assert \"DFAE\" in tickers\n    assert \"EEM\" in tickers\n\n@patch(\"src.db.create_engine\")\ndef test_db_polling(mock_create_engine):\n    from src.db import wait_for_db\n    mock_create_engine.side_effect = [Exception(\"Connection failed\")] * 9 + [MagicMock()]\n    \n    wait_for_db()\n    assert mock_create_engine.call_count == 10\n"
          }
        },
        "inline_data": null,
