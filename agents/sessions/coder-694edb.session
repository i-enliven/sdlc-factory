          "name": "run_cli_command",
          "response": {
            "result": "from fastapi import FastAPI\nfrom contextlib import asynccontextmanager\nfrom src.db import poll_database, seed_data\nfrom src.logic import calculate_premium\n\n@asynccontextmanager\nasync def lifespan(app: FastAPI):\n    poll_database()\n    seed_data()\n    yield\n\napp = FastAPI(lifespan=lifespan)\n\n@app.get(\"/api/health\")\ndef health():\n    return {\"status\": \"ok\"}\n\n@app.get(\"/api/heatmap\")\ndef heatmap(fund_id: str, timeframe: str):\n    return [[1, 2, 3], [4, 5, 6]]\n"
          }
        },
        "inline_data": null,
